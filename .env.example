# Port the server listens on
PORT=7000

# Public base URL used in poster image and manifest links.
# Set this to the address Stremio will use to reach this server.
# On the same machine the default works fine.
# On a remote server or NAS, set this to your LAN or public address.
# Example: BASE_URL=http://192.168.1.100:7000
BASE_URL=http://127.0.0.1:7000
